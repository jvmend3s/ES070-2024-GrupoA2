void vBleCmdMotorLeftward(){
	vMotorsSetPWM(left, 0.8, 1);
	vMotorsSetPWM(right, 0.1, 0);
	HAL_Delay(500);
	vMotorsSetOff(left);
	vMotorsSetOff(right);
}

void vBleCmdMotorRightward(){
	vMotorsSetPWM(left, 0.1, 1);
	vMotorsSetPWM(right, 0.8, 0);
	HAL_Delay(500);
	vMotorsSetOff(left);
	vMotorsSetOff(right);

}
